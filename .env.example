# Database
DATABASE_URL=file:./hireflow.db

# NextAuth
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Featherless AI (leave empty for demo mode with mock data)
FEATHERLESS_API_KEY=

# AI Model (optional - defaults to Llama 3.3 70B)
AI_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Band API — one External Agent per role (https://app.band.ai/agents).
# Live mode requires all 5 keys; leave empty for mock mode.
BAND_API_URL=https://app.band.ai/api/v1/agent
# Human API key — run `npm run band:create` to auto-create the 5 agents below.
BAND_HUMAN_API_KEY=
BAND_RESUME_ANALYST_KEY=
BAND_RESUME_ANALYST_ID=
BAND_TECHNICAL_EVALUATOR_KEY=
BAND_TECHNICAL_EVALUATOR_ID=
BAND_CULTURE_EVALUATOR_KEY=
BAND_CULTURE_EVALUATOR_ID=
BAND_COMPENSATION_AGENT_KEY=
BAND_COMPENSATION_AGENT_ID=
BAND_RANKING_AGENT_KEY=
BAND_RANKING_AGENT_ID=
# Optional: who the Ranking Agent @mentions for human approval (User UUID or Agent ID)
BAND_REVIEWER_ID=
